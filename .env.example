# Watchtower secrets. Copy to .env and fill in.
# .env is gitignored — never commit real values.

# Telegram alerts (uses @spitmuxclawd_bot on the homelab)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Per-camera Tapo credentials are keyed by camera name (uppercased).
# Example for camera named "c230" in config.yaml:
TAPO_PASSWORD_C230=

# Bearer token for non-Tailscale/LAN API access. Leave blank to let
# watchtower-api generate one on first run and write it to config.yaml.
WATCHTOWER_BEARER_TOKEN=

# NATS URL. Default assumes nats-server runs on localhost.
WATCHTOWER_NATS_URL=nats://127.0.0.1:4222
